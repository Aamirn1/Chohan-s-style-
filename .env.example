# Supabase PostgreSQL connection
# Copy this file to .env and replace [YOUR-PASSWORD] with your actual database password
# Get your password from: https://supabase.com/dashboard/project/tjcrfmwmsjchiabidtzy/settings/database

# Transaction-mode pooler (IPv4) - used by the app at runtime (PgBouncer)
DATABASE_URL="postgresql://postgres.tjcrfmwmsjchiabidtzy:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session-mode pooler (direct) - used for migrations/db push
DIRECT_URL="postgresql://postgres.tjcrfmwmsjchiabidtzy:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"
